# ============================================================
# AssetFlow Backend — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your PostgreSQL credentials.
# DO NOT commit .env to version control.
# ============================================================

# Server
PORT=5000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/assetflow
# Or use individual vars:
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_NAME=assetflow

# JWT
JWT_SECRET=assetflow-hackathon-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS — React frontend origin
CORS_ORIGIN=http://localhost:5173

# Password reset token expiry (in minutes)
RESET_TOKEN_EXPIRY_MINUTES=60
